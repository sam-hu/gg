{
  "name": "gg-stacked-cli",
  "version": "0.1.0",
  "description": "A local, GitHub-native stacked-branch CLI",
  "type": "module",
  "private": true,
  "bin": {
    "gg": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "prebuild": "npm run clean",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:install": "node scripts/smoke-install.mjs",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.0.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^24.10.0",
    "eslint": "^9.39.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^4.0.0"
  }
}
